{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "dist",
    "baseUrl": ".",
    "moduleResolution": "Node",
    "paths": {
      "@cv-standardizer/shared-contracts": [
        "../../packages/shared-contracts/src/index"
      ]
    },
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
