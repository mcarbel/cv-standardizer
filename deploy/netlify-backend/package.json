{
  "name": "cv-standardizer-netlify-backend",
  "private": true,
  "version": "0.1.1",
  "scripts": {
    "build": "npm run build:contracts && npm run build:backend",
    "build:contracts": "npm --prefix packages/shared-contracts run build",
    "build:backend": "tsc -p tsconfig.json",
    "dev": "netlify dev",
    "start": "netlify dev"
  },
  "dependencies": {
    "@cv-standardizer/shared-contracts": "file:packages/shared-contracts",
    "cors": "^2.8.5",
    "docx": "^9.0.3",
    "express": "^4.21.1",
    "mammoth": "^1.9.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.80.1",
    "pdf-parse": "^1.1.1",
    "pdf-lib": "^1.17.1",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.1",
    "netlify-cli": "^17.38.1",
    "typescript": "^5.6.3"
  }
}
