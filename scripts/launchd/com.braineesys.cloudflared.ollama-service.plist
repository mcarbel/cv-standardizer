<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.braineesys.cloudflared.ollama-service</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/cloudflared</string>
    <string>tunnel</string>
    <string>--config</string>
    <string>/Users/otakoo/.cloudflared/ollama-service.yml</string>
    <string>run</string>
    <string>ollama-service</string>
  </array>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/otakoo/Library/Logs/cv-standardizer/ollama-tunnel.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/otakoo/Library/Logs/cv-standardizer/ollama-tunnel.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>/Users/otakoo</string>
  </dict>
</dict>
</plist>
